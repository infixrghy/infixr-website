node_modules/
.tmp/
*.log

# build output — generated by build.ts, deployed by CI
public/

# byte-diff baseline (local refactor gate only)
.baseline/
.DS_Store
Thumbs.db
.idea/
.vscode/
.claude/settings.local.json

# scratch (local only)
.satoshi-fontshare.css

# design refs — Figma exports, mockups (local only; Figma is canonical).
# Ignore the CONTENTS (design/*, not design/) so the negation below can
# re-include a file — git can't re-include through an excluded *directory*.
design/*
# …except committed design DOCS (e.g. the glass-card component spec, which
# SPEC.md V36 + code comments reference — must ship so those refs resolve).
!design/GLASS-CARD.md

# fallow's local cache (incremental analysis). The config (.fallowrc.jsonc) and
# the agent gate (.claude/) ARE committed; only this cache dir is local.
.fallow/

# session handoff notes (local only — scratch for cross-session continuity)
.handoff/
.t41-baseline/
